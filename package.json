{
	"name": "onlineornot-root",
	"version": "0.0.0",
	"private": true,
	"description": "Monorepo for onlineornot and associated packages",
	"homepage": "https://github.com/onlineornot/onlineornot#readme",
	"bugs": {
		"url": "https://github.com/cloudflare/onlineornot/issues"
	},
	"license": "MIT",
	"author": "max@onlineornot.com",
	"scripts": {
		"build": "pnpm --filter onlineornot run build",
		"check": "run-p check:* --aggregate-output --continue-on-error",
		"check:format": "prettier . --check --ignore-unknown",
		"check:lint": "eslint \"packages/**/*.[tj]s?(x)\" --cache --cache-strategy content --max-warnings=0",
		"check:type": "pnpm -r --if-present run check:type",
		"fix": "pnpm run prettify && pnpm run check:lint -- --fix",
		"prettify": "prettier . --write --ignore-unknown",
		"test": "pnpm --filter onlineornot run clean && pnpm --filter onlineornot run bundle && pnpm --filter onlineornot run test",
		"test:ci": "pnpm --filter onlineornot run test:ci"
	},
	"dependencies": {
		"@changesets/changelog-github": "^0.4.5",
		"@changesets/cli": "^2.22.0",
		"@types/jest": "^28.1.6",
		"@types/node": "^16.11.11",
		"@typescript-eslint/eslint-plugin": "^5.46.0",
		"@typescript-eslint/parser": "^5.46.0",
		"cross-env": "^7.0.3",
		"esbuild-jest": "0.5.0",
		"esbuild-register": "^3.3.2",
		"eslint": "^8.13.0",
		"eslint-plugin-import": "^2.26.0",
		"eslint-plugin-react": "^7.29.4",
		"eslint-plugin-react-hooks": "^4.4.0",
		"eslint-plugin-unused-imports": "^2.0.0",
		"jest": "^28.1.3",
		"npm-run-all": "^4.1.5",
		"prettier": "^2.6.2",
		"prettier-plugin-packagejson": "^2.2.18",
		"rimraf": "^3.0.2",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20221111.1"
	},
	"engines": {
		"node": ">=22"
	},
	"volta": {
		"node": "22.16.0"
	}
}
