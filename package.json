{
	"name": "onlineornot-root",
	"version": "0.0.0",
	"private": true,
	"description": "Monorepo for onlineornot and associated packages",
	"homepage": "https://github.com/onlineornot/onlineornot#readme",
	"bugs": {
		"url": "https://github.com/cloudflare/onlineornot/issues"
	},
	"license": "MIT",
	"author": "max@onlineornot.com",
	"scripts": {
		"build": "pnpm --filter onlineornot run build",
		"check": "run-p check:* --aggregate-output --continue-on-error",
		"check:format": "oxfmt --check .",
		"check:lint": "oxlint --deny-warnings",
		"check:type": "pnpm -r --if-present run check:type",
		"fix": "oxfmt --write . && oxlint --fix",
		"test": "pnpm --filter onlineornot run clean && pnpm --filter onlineornot run bundle && pnpm --filter onlineornot run test",
		"test:ci": "pnpm --filter onlineornot run test:ci",
		"prepare": "husky"
	},
	"dependencies": {
		"@changesets/changelog-github": "^0.4.5",
		"@changesets/cli": "^2.22.0",
		"@types/jest": "^28.1.6",
		"@types/node": "^16.11.11",
		"cross-env": "^7.0.3",
		"esbuild-jest": "0.5.0",
		"esbuild-register": "^3.3.2",
		"jest": "^28.1.3",
		"npm-run-all": "^4.1.5",
		"rimraf": "^3.0.2",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20221111.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"oxfmt": "^0.36.0",
		"oxlint": "^1.51.0"
	},
	"lint-staged": {
		"*.{js,ts,tsx,jsx,mjs,cjs}": [
			"oxfmt --write",
			"oxlint --fix"
		]
	},
	"engines": {
		"node": ">=22"
	},
	"volta": {
		"node": "22.16.0"
	}
}
